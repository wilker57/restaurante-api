### GET Buscar Todos os Bairros
GET http://localhost:8080/bairro

### GET Buscar Bairro por Codigo
GET http://localhost:8080/bairro/codigo/1

### GET Buscar Bairro por Nome
GET http://localhost:8080/bairro/nome/centro

### POST Inserir Bairro
POST http://localhost:8080/bairro
Content-Type: application/json
Accept: application/json

{
  "nome": "Jardim Mariana",
  "custoEntrega": 9
}

### PUT Alterar Bairro
PUT http://localhost:8080/bairro
Content-Type: application/json
Accept: application/json

{
  "codigo": 4,
  "nome": "Paiaguais",
  "custoEntrega": 12
}

### DELETE Excluir Bairro
DELETE http://localhost:8080/bairro/5

### GET Buscar todos os Clientes
GET http://localhost:8080/cliente

### GET Buscar Clientes por Codigo
GET http://localhost:8080/cliente/codigo/1

### GET Buscar Clientes por Nome
GET http://localhost:8080/cliente/nome/Cliente 02

### POST Buscar Endereco por CEP
POST http://localhost:8080/cliente/cep
Content-Type: application/json
Accept: application/json

{
  "cep": "78104970"
}

### POST Inserir Cliente
POST http://localhost:8080/cliente
Content-Type: application/json
Accept: application/json

{
"nome": "Cliente Feliz",
"rg": "412337265-6",
"cpf": "223.699.5950-60",
"telefone": "65 99999-9999",
"logradouro": "Rua Pernambuco",
"numero": "679",
"pontoReferencia": "Rua Sem Saída",
"bairro": {
  "codigo": 1,
  "nome": "Centro",
  "custoEntrega": 8.0
}
}

