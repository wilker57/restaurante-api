  "rg": "41233773-6",
  "cpf": "218.699.5950-61",
  "telefone": "65 99999-9999",
  "cep": "78104970",
  "numero": "679",
  "pontoReferencia": "Casa azul"
}

### PUT Alterar Cliente
PUT http://localhost:8080/cliente
Content-Type: application/json
Accept: application/json

{
  "codigo": 1,
  "nome": "Cliente Alegre",
  "rg": "41233773-6",
  "cpf": "218.699.5950-60",
  "telefone": "65 99999-9999",
  "cep": "78104970",
  "logradouro": "Rua Paraná",
  "numero": "679",
  "pontoReferencia": "Próximo Igreja II",
  "bairro": {
    "codigo": 3,
    "nome": "Jardim Mariana",
    "custoEntrega": 8.0
  }
}

